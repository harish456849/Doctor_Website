<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee
                             http://xmlns.jcp.org/xml/ns/javaee/web-app_3_1.xsd"
         version="3.1">

    <display-name>HospitalProject</display-name>

    <servlet>
        <servlet-name>DoctorLoginServlet</servlet-name>
        <servlet-class>DoctorLoginServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>DoctorLoginServlet</servlet-name>
        <url-pattern>/doctor-login</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>DoctorRegisterServlet</servlet-name>
        <servlet-class>DoctorRegisterServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>DoctorRegisterServlet</servlet-name>
        <url-pattern>/doctor-register</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>PatientLoginServlet</servlet-name>
        <servlet-class>PatientLoginServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>PatientLoginServlet</servlet-name>
        <url-pattern>/patient-login</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>PatientRegisterServlet</servlet-name>
        <servlet-class>PatientRegisterServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>PatientRegisterServlet</servlet-name>
        <url-pattern>/patient-register</url-pattern>
    </servlet-mapping>

    <welcome-file-list>
        <welcome-file>index.html</welcome-file>
    </welcome-file-list>
</web-app>
